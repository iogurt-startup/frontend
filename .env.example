# Google OAuth
VITE_GOOGLE_CLIENT_ID=
CALENDAR_API=
GOOGLE_CLIENT_ID=

# URL base da API.
# Deixe em branco para usar o padrão same-origin '/api' (recomendado): as
# chamadas passam pelo reverse proxy (nginx em prod, proxy do Vite em dev) e
# nunca disparam CORS. Defina apenas para apontar a uma API de outra origem.
# VITE_API_URL=/api

# Apenas para `npm run dev` (Vite): destino do proxy de /api.
# Padrão: http://localhost:3001 (porta publicada pelo docker-compose do backend).
# VITE_DEV_API_PROXY=http://localhost:3001

# E2E Tests
BASE_URL=
API_URL=
